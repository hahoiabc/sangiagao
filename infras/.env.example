# ============================================
# Rice Marketplace - Cấu hình môi trường
# ============================================
# Copy file này thành .env và điền giá trị phù hợp.
# cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=rice_marketplace
POSTGRES_USER=rice_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=5435

# --- Redis ---
REDIS_PORT=6381

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=rice_user
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME
MONGO_INITDB_DATABASE=rice_chat
MONGO_PORT=27018

# --- Backend (Golang) ---
APP_ENV=development
BACKEND_PORT=8080
JWT_SECRET=CHANGE_ME_MUST_BE_AT_LEAST_32_CHARS
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=720h

# --- Chat (Phoenix) ---
CHAT_PORT=4000
PHOENIX_SECRET_KEY_BASE=CHANGE_ME_MUST_BE_AT_LEAST_64_CHARS

# --- External Services ---
SMS_API_KEY=
SMS_PROVIDER=mock
CLOUDINARY_URL=
FIREBASE_CRED_PATH=

# --- Apple In-App Purchase ---
# App Store Connect API Key (for IAP receipt verification + Server Notifications V2)
# Generate at https://appstoreconnect.apple.com/access/integrations/api
APP_STORE_KEY_ID=
APP_STORE_ISSUER_ID=
APP_STORE_KEY_PATH=/Users/hahoi83/.appstoreconnect/private_keys/AuthKey_KEYID.p8
APP_STORE_BUNDLE_ID=com.sangiagao.riceMarketplace
APP_STORE_ENV=Sandbox
