# ============================================
# Rice Marketplace - Cấu hình PRODUCTION
# ============================================
# 1. Copy file này: cp .env.production.example .env.production
# 2. Thay TẤT CẢ giá trị bên dưới bằng secrets thật
# 3. KHÔNG commit .env.production lên git!
# 4. Tạo secrets: openssl rand -hex 32

# --- Domain ---
DOMAIN=YOUR_DOMAIN.com
ADMIN_DOMAIN=admin.YOUR_DOMAIN.com

# --- PostgreSQL ---
POSTGRES_DB=rice_marketplace
POSTGRES_USER=rice_user
POSTGRES_PASSWORD=THAY_BANG_PASSWORD_MANH    # openssl rand -hex 24
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=THAY_BANG_PASSWORD_MANH       # openssl rand -hex 24

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=rice_user
MONGO_INITDB_ROOT_PASSWORD=THAY_BANG_PASSWORD_MANH  # openssl rand -hex 24
MONGO_INITDB_DATABASE=rice_chat
MONGO_PORT=27017

# --- Backend (Golang) ---
APP_ENV=production
BACKEND_PORT=8080
JWT_SECRET=THAY_BANG_64_HEX_CHARS            # openssl rand -hex 32
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=720h

# --- Chat (Phoenix) ---
CHAT_PORT=4000
PHOENIX_SECRET_KEY_BASE=THAY_BANG_96_HEX_CHARS  # openssl rand -hex 48

# --- Phone Encryption (AES-256) ---
PHONE_ENCRYPT_KEY=THAY_BANG_64_HEX_CHARS     # openssl rand -hex 32

# --- MinIO ---
MINIO_ROOT_USER=rice_minio
MINIO_ROOT_PASSWORD=THAY_BANG_PASSWORD_MANH  # openssl rand -hex 24
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=rice-images
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=https://YOUR_DOMAIN.com/images

# --- External Services ---
SMS_API_KEY=THAY_BANG_API_KEY_THAT
SMS_PROVIDER=esms                            # hoặc nhà cung cấp SMS thật
CLOUDINARY_URL=
FIREBASE_CRED_PATH=/app/firebase-credentials.json

# --- Backend internal (dùng trong Go) ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=rice_user
DB_PASSWORD=THAY_BANG_PASSWORD_MANH          # giống POSTGRES_PASSWORD
DB_NAME=rice_marketplace
DB_SSL_MODE=require
REDIS_URL=redis://:THAY_BANG_PASSWORD_MANH@redis:6379  # password giống REDIS_PASSWORD
CORS_ORIGINS=https://YOUR_DOMAIN.com,https://admin.YOUR_DOMAIN.com
COOKIE_DOMAIN=YOUR_DOMAIN.com
COOKIE_SECURE=true
RATE_LIMIT_RPS=30
RATE_LIMIT_BURST=60
