# ============================================
# Rice Marketplace - Production Environment
# ============================================
# Copy file này thành .env.production và thay đổi giá trị
# KHÔNG commit file .env.production lên git!

# --- PostgreSQL ---
POSTGRES_DB=rice_marketplace
POSTGRES_USER=rice_user
POSTGRES_PASSWORD=THAY_DOI_MAT_KHAU_MANH_TAI_DAY

# --- Redis ---
REDIS_PASSWORD=THAY_DOI_MAT_KHAU_REDIS_TAI_DAY

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=rice_user
MONGO_INITDB_ROOT_PASSWORD=THAY_DOI_MAT_KHAU_MONGO_TAI_DAY
MONGO_INITDB_DATABASE=rice_chat

# --- Backend (Go) ---
JWT_SECRET=THAY_DOI_BANG_CHUOI_NGAU_NHIEN_64_KY_TU_HEX
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=720h

# --- Phone Encryption (AES-256, 64 hex chars) ---
# Tạo: openssl rand -hex 32
PHONE_ENCRYPT_KEY=THAY_DOI_BANG_CHUOI_NGAU_NHIEN_64_KY_TU_HEX

# --- Chat (Phoenix) ---
# Tạo: mix phx.gen.secret
PHOENIX_SECRET_KEY_BASE=THAY_DOI_BANG_CHUOI_NGAU_NHIEN_DAI

# --- MinIO ---
MINIO_ROOT_USER=rice_minio_admin
MINIO_ROOT_PASSWORD=THAY_DOI_MAT_KHAU_MINIO_TAI_DAY
MINIO_PUBLIC_URL=https://YOUR_DOMAIN.com/images

# --- Domain ---
PHX_HOST=YOUR_DOMAIN.com
CORS_ORIGINS=https://admin.YOUR_DOMAIN.com

# --- SMS (production) ---
SMS_PROVIDER=esms
SMS_API_KEY=YOUR_SMS_API_KEY

# --- Backup ---
# Giữ backup trong bao nhiêu ngày
BACKUP_RETENTION_DAYS=30
